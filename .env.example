# Site personalization (optional — or edit via Settings after sign-in)
NEXT_PUBLIC_SITE_OWNER_NAME=Your Name
NEXT_PUBLIC_SITE_TITLE=Your Name's Climbs
NEXT_PUBLIC_SITE_TAGLINE=Mountain climbs, mapped in 3D
NEXT_PUBLIC_SITE_BIO=A short intro about you and your climbing.
NEXT_PUBLIC_SITE_FOOTER=Thanks for following along on the trail.

# Set to false to skip the demo Mount Washington climb
SEED_SAMPLE_CLIMB=false

NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Only you can upload GPX files — pick a strong private password
ADMIN_PASSWORD=your_secret_password_here

# Optional: separate signing key for login sessions (defaults to ADMIN_PASSWORD)
SESSION_SECRET=random_long_string_here

# Vercel Blob — added automatically when you connect a Blob store to this project
# BLOB_STORE_ID=
# BLOB_READ_WRITE_TOKEN=
# Set to "public" only if your Blob store was created as public (default is private)
# BLOB_ACCESS=private
